[Unit]
Description=CTOA mobile console API
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/opt/ctoa
EnvironmentFile=-/opt/ctoa/.env
ExecStart=/opt/ctoa/.venv/bin/python3 -m uvicorn mobile_console.app:app --host 0.0.0.0 --port 8787
Restart=always
RestartSec=3
StandardOutput=append:/opt/ctoa/logs/mobile-console.log
StandardError=append:/opt/ctoa/logs/mobile-console.log

[Install]
WantedBy=multi-user.target
