# CTOAi environment variables
# Copy to .env and fill in real values — never commit .env!
CTOA_ENV_FILE=.env

# ── Database ───────────────────────────────────────────────────────────────────
DB_NAME=ctoa
DB_USER=ctoa
DB_PASSWORD=change_me_strong_password

# ── Redis ──────────────────────────────────────────────────────────────────────
# Leave empty to run Redis without auth (dev only).
REDIS_PASSWORD=change_me_redis_password

# ── Grafana ────────────────────────────────────────────────────────────────────
GF_ADMIN_USER=admin
GF_ADMIN_PASSWORD=change_me_grafana_password

# ── Mobile Console ────────────────────────────────────────────────────────────
CTOA_MOBILE_TOKEN=change_me_mobile_token

# ── VPS deploy (used by CD workflow, set in GitHub Secrets for CI) ─────────────
# VPS_HOST=your-vps-ip-or-hostname
# VPS_USERNAME=ctoa
# VPS_SSH_KEY_B64=<base64-encoded private key>
# VPS_BOT_ENV=<base64-encoded .env.bot contents>
# CTOA_VPS_ENV_B64=<base64-encoded /opt/ctoa/.env — used by vps-stack-deploy.yml>
# ── LLM Provider ──────────────────────────────────────────────────────────────
# Local backend (Ollama) is the default. When routing via Groq, set both SMALL and LARGE vars.
# CTOA_LLM_PROVIDER options: auto | local | azure
CTOA_LOCAL_MODEL_URL=http://host.docker.internal:11434/v1
CTOA_LOCAL_MODEL_NAME=ctoa-1.5b
# Local model alternatives (Ollama): qwen2.5-coder:1.5b, phi4-mini, gemma3:1b,
#   deepseek-coder:1.3b (code focus), qwen2.5-coder:7b or codellama:7b (if ≥8 GB RAM)

CTOA_MODEL_SMALL=llama-3.1-8b-instant
CTOA_SMALL_MODEL_URL=https://api.groq.com/openai/v1
CTOA_SMALL_API_KEY=<groq_free_key>
# Groq small-model alternatives: gemma2-9b-it, llama-3.2-3b-preview, mistral-saba-24b

CTOA_MODEL_LARGE=llama-3.3-70b-versatile
CTOA_LARGE_MODEL_URL=https://api.groq.com/openai/v1
CTOA_LARGE_API_KEY=<groq_free_key>
# Groq large-model alternatives: deepseek-r1-distill-llama-70b (reasoning),
#   qwen-qwq-32b (reasoning), llama-3.1-70b-versatile (fallback)

CTOA_ROUTE_DEFAULT=auto


