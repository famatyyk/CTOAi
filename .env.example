# CTOAi environment variables
# Copy to .env and fill in real values — never commit .env!
CTOA_ENV_FILE=.env

# ── Database ───────────────────────────────────────────────────────────────────
DB_NAME=ctoa
DB_USER=ctoa
DB_PASSWORD=change_me_strong_password

# ── Redis ──────────────────────────────────────────────────────────────────────
# Leave empty to run Redis without auth (dev only).
REDIS_PASSWORD=change_me_redis_password

# ── Grafana ────────────────────────────────────────────────────────────────────
GF_ADMIN_USER=admin
GF_ADMIN_PASSWORD=change_me_grafana_password

# ── Mobile Console ────────────────────────────────────────────────────────────
CTOA_MOBILE_TOKEN=change_me_mobile_token
CTOA_SELF_REGISTER_ENABLED=false
CTOA_SELF_REGISTER_CODE=
# Optional override for local HTTP dev. Leave empty to auto-enable secure cookie only in prod.
CTOA_SESSION_COOKIE_SECURE=
# Production defaults reject localhost/private Intel targets. Enable only for a
# trusted private target behind your own network controls.
CTOA_ALLOW_PRIVATE_INTEL_TARGETS=false
# Optional Intel client sync. Write paths are confined to CTOA_CLIENT_SCRIPTS_DIR.
CTOA_CLIENT_SYNC_ENABLED=false
CTOA_CLIENT_SCRIPTS_DIR=
CTOA_CLIENT_TARGET_SLUG=intel_target
CTOA_CLIENT_AUTOLOADER_NAME=ctoa_intel_autoload.lua
CTOA_CLIENT_INIT_FILE=

# ── API auth / CORS ───────────────────────────────────────────────────────────
# In production, set CTOA_ENV=production, use a non-default JWT secret, and
# replace wildcard CORS with explicit trusted origins.
CTOA_ENV=development
CTOA_JWT_SECRET=change_me_ctoa_jwt_secret
CTOA_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CTOA_AUTH_STORE_FILE=runtime/state/auth_store.json
# Leave false unless CTOAi is running behind a trusted reverse proxy that
# overwrites client IP headers. When false, FastAPI and web proxy rate limits
# ignore X-Forwarded-For/X-Real-IP.
CTOA_TRUST_PROXY_HEADERS=false
# API public member signup defaults off in production. If enabled in production,
# set a registration code and pass it as registration_code.
CTOA_API_SELF_REGISTER_ENABLED=false
CTOA_API_SELF_REGISTER_CODE=
# Dev convenience only. Keep off unless you explicitly want local seed accounts.
CTOA_ALLOW_SEED_ACCOUNTS=false
CTOA_ENABLE_LOCAL_SEED_LOGIN=false
CTOA_SEED_RECRUIT_PASSWORD=
CTOA_SEED_STRATEGOS_PASSWORD=
CTOA_SEED_FAMATYYK_PASSWORD=

# ── VPS deploy (used by CD workflow, set in GitHub Secrets for CI) ─────────────
# VPS_HOST=your-vps-ip-or-hostname
# VPS_USERNAME=ctoa
# VPS_SSH_KEY_B64=<base64-encoded private key>
# VPS_BOT_ENV=<base64-encoded .env.bot contents>
# CTOA_VPS_ENV_B64=<base64-encoded /opt/ctoa/.env — used by vps-stack-deploy.yml>
# ── LLM Provider ──────────────────────────────────────────────────────────────
# Local backend (Ollama) is the default. When routing via Groq, set both SMALL and LARGE vars.
CTOA_LOCAL_MODEL_URL=http://host.docker.internal:11434/v1
CTOA_LOCAL_MODEL_NAME=ctoa-1.5b
CTOA_MODEL_SMALL=llama-3.1-8b-instant
CTOA_SMALL_MODEL_URL=https://api.groq.com/openai/v1
CTOA_SMALL_API_KEY=<groq_free_key>
CTOA_MODEL_LARGE=llama-3.3-70b-versatile
CTOA_LARGE_MODEL_URL=https://api.groq.com/openai/v1
CTOA_LARGE_API_KEY=<groq_free_key>
CTOA_ROUTE_DEFAULT=auto

# ── API Auth/Security ─────────────────────────────────────────────────────────
CTOA_AUTH_BOOTSTRAP_CODE=change_this_bootstrap_code

# ── Local network exposure ────────────────────────────────────────────────────
# Keep local services on loopback by default. Set to 0.0.0.0 only when you
# intentionally need access from another device or a trusted VPN/LAN.
CTOA_BIND_HOST=127.0.0.1
CTOA_BOT_DASHBOARD_BIND_HOST=127.0.0.1
CTOA_MONITOR_BIND_HOST=127.0.0.1

# ── Discovery agents ──────────────────────────────────────────────────────────
# Discovery uses verified TLS by default. Enable these only for a trusted legacy
# target with broken certificates.
CTOA_CATALOG_ALLOW_INSECURE_SSL=false
CTOA_SCOUT_ALLOW_INSECURE_SSL=false
CTOA_INGEST_ALLOW_INSECURE_SSL=false

# ── Reporting / evidence ──────────────────────────────────────────────────────
CTOA_RELEASES_DIR=releases/evidence
CTOA_REPO_HYGIENE_PATH=runtime/repo-hygiene/local-pr-quality.json
CTOA_API_COST_RUNS_DIR=evals/runs
CTOA_API_COST_REPORT_PATH=runtime/api-cost/latest.json
CTOA_API_COST_JSON_OUT=runtime/api-cost/latest.json
CTOA_API_COST_MD_OUT=runtime/api-cost/latest.md
CTOA_API_COST_MD_PATH=runtime/api-cost/latest.md
CTOA_EVAL_DATASET_PATH=evals/azure-activity-agent-eval-dataset.template.jsonl
CTOA_PROMPT_VARIANTS_DIR=evals/prompt-variants
CTOA_ACTION_AUDIT_PATH=runtime/control-center/action-audit.jsonl
CTOA_EVIDENCE_JSON_PATH=runtime/evidence/latest.json
CTOA_EVIDENCE_MD_PATH=runtime/evidence/latest.md
CTOA_HELPER_DEV_DIR=runtime/solteria_helper_dev
CTOA_HELPER_MANIFEST_PATH=runtime/solteria_helper_dev/manifest.json
CTOA_HELPER_VALIDATION_PATH=runtime/solteria_helper_dev/validation.json
CTOA_HELPER_RELEASE_READINESS_PATH=runtime/solteria_helper_dev/release_readiness.json
CTOA_HELPER_RELEASE_GATE_PATH=runtime/solteria_helper_dev/release_gate.json
CTOA_HELPER_GOAL_STATUS_PATH=runtime/solteria_helper_dev/goal_status.json
CTOA_HELPER_SMOKE_PREFLIGHT_PATH=runtime/solteria_helper_dev/smoke_preflight.json
CTOA_HELPER_SMOKE_STATUS_PATH=runtime/solteria_helper_dev/smoke_status.json
CTOA_HELPER_LIVE_PROMOTION_PATH=runtime/solteria_helper_dev/live_promotion.json
CTOA_HELPER_BACKGROUND_STATUS_PATH=runtime/solteria_helper_dev/background_status.json
CTOA_HELPER_CONDITIONS_SHADOW_REPLAY_PATH=runtime/solteria_helper_dev/conditions_shadow_replay.json
CTOA_ENGINE_BRAIN_MANIFEST_PATH=AI/generated/manifest.json
CTOA_ENGINE_BRAIN_PACK_MANIFEST_PATH=AI/generated/ENGINE_BRAIN_PACK.json
CTOA_ENGINE_BRAIN_OWNERSHIP_MAP_PATH=AI/generated/OWNERSHIP_MAP.md
CTOA_ENGINE_BRAIN_DOC_SYNC_PATH=AI/generated/DOC_SYNC.json
CTOA_ENGINE_BRAIN_SECRET_GUARDRAIL_PATH=AI/generated/SECRET_GUARDRAIL.json
