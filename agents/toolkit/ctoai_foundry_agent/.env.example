# Azure AI Foundry endpoint (from ai.azure.com → Project → Overview → Target URI)
# Format: https://<hub-name>.cognitiveservices.azure.com/
FOUNDRY_ENDPOINT=https://ctoai.cognitiveservices.azure.com/
FOUNDRY_API_KEY=<your-api-key>
FOUNDRY_API_VERSION=2025-01-01-preview

# Deployments — gpt-4o for both (gpt-4o-mini deprecated since 03/2026)
MODEL_MAIN_DEPLOYMENT=gpt-4o
MODEL_MINI_DEPLOYMENT=gpt-4o

# Local evidence sink
EVIDENCE_FILE=runtime/evidence/aitk-agent/ctoai_foundry_agent.jsonl
