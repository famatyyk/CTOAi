# Microsoft Foundry / Azure OpenAI endpoint
FOUNDRY_ENDPOINT=https://<your-project>.openai.azure.com/
FOUNDRY_API_KEY=<your-api-key>
FOUNDRY_API_VERSION=2024-10-21

# Deployments
MODEL_MAIN_DEPLOYMENT=gpt-4.1
MODEL_MINI_DEPLOYMENT=gpt-4.1-mini

# Local evidence sink
EVIDENCE_FILE=runtime/evidence/aitk-agent/ctoai_foundry_agent.jsonl
