{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ctoai.local/schemas/ctoa-p14-guest-evidence-envelope.schema.json",
  "title": "CTOAi P14 guest evidence envelope",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "algorithm",
    "key_id",
    "payload_b64",
    "payload_sha256",
    "signature"
  ],
  "properties": {
    "schema_version": {
      "const": "ctoa.p14-guest-evidence-envelope.v1"
    },
    "algorithm": {
      "const": "ecdsa-p256-sha256"
    },
    "key_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]{2,63}$"
    },
    "payload_b64": {
      "type": "string",
      "minLength": 4,
      "maxLength": 131072,
      "pattern": "^[A-Za-z0-9+/]+={0,2}$"
    },
    "payload_sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "signature": {
      "type": "string",
      "minLength": 8,
      "maxLength": 2048,
      "pattern": "^[A-Za-z0-9+/]+={0,2}$"
    }
  }
}
