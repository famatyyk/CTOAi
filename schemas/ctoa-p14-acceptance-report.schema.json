{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ctoai.local/schemas/ctoa-p14-acceptance-report.schema.json",
  "title": "CTOAi P14 isolated acceptance observation report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "generated_at",
    "source_revision",
    "isolation",
    "capabilities"
  ],
  "properties": {
    "schema_version": {"const": "ctoa.p14-acceptance-report.v1"},
    "generated_at": {"type": "string", "format": "date-time"},
    "source_revision": {"type": "string", "pattern": "^[a-f0-9]{40}$"},
    "isolation": {"$ref": "#/$defs/isolation"},
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "maxItems": 4,
      "items": {"$ref": "#/$defs/capabilityResult"}
    }
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "capability": {
      "enum": [
        "visual_regression",
        "in_world_regression",
        "canary_rehearsal",
        "rollback_rehearsal"
      ]
    },
    "proof": {
      "type": "object",
      "additionalProperties": false,
      "required": ["proof_id", "status", "artifact_count", "evidence_sha256"],
      "properties": {
        "proof_id": {
          "enum": [
            "isolated_visual_capture",
            "independent_visual_review",
            "isolated_client_launch",
            "helper_runtime_smoke",
            "independent_in_world_review",
            "sandbox_canary_apply",
            "canary_health_check",
            "rollback_apply",
            "baseline_restore_verified"
          ]
        },
        "status": {"enum": ["passed", "blocked"]},
        "artifact_count": {"type": "integer", "minimum": 0, "maximum": 16},
        "evidence_sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "transition": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "baseline_manifest_sha256",
        "changed_manifest_sha256",
        "restored_manifest_sha256",
        "changed_file_count"
      ],
      "properties": {
        "baseline_manifest_sha256": {"$ref": "#/$defs/sha256"},
        "changed_manifest_sha256": {"$ref": "#/$defs/sha256"},
        "restored_manifest_sha256": {"$ref": "#/$defs/sha256"},
        "changed_file_count": {"type": "integer", "minimum": 1, "maximum": 256}
      }
    },
    "capabilityResult": {
      "type": "object",
      "additionalProperties": false,
      "required": ["capability", "status", "proofs", "transition"],
      "properties": {
        "capability": {"$ref": "#/$defs/capability"},
        "status": {"enum": ["passed", "blocked"]},
        "proofs": {
          "type": "array",
          "minItems": 2,
          "maxItems": 3,
          "items": {"$ref": "#/$defs/proof"}
        },
        "transition": {
          "oneOf": [
            {"type": "null"},
            {"$ref": "#/$defs/transition"}
          ]
        }
      }
    },
    "isolation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "isolated_environment",
        "operator_workstation_focus_used",
        "operator_workstation_input_used",
        "network_dispatch_used",
        "live_client_accessed",
        "promotion_attempted"
      ],
      "properties": {
        "isolated_environment": {"const": true},
        "operator_workstation_focus_used": {"const": false},
        "operator_workstation_input_used": {"const": false},
        "network_dispatch_used": {"const": false},
        "live_client_accessed": {"const": false},
        "promotion_attempted": {"const": false}
      }
    }
  }
}
