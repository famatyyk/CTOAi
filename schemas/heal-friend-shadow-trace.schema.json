{
  "$schema":"https://json-schema.org/draft/2020-12/schema",
  "$id":"https://ctoa.local/schemas/heal-friend-shadow-trace.schema.json",
  "title":"CTOAi Heal Friend fixture shadow trace v1",
  "type":"object",
  "additionalProperties":false,
  "required":["schema_version","trace_id","source","evaluated_at_unix_ms","mode","status","decision","action","spell","input_sha256","canonical_input_sha256","observation_age_ms","party_observation_age_ms","blockers","plan","decision_sha256","fixture_validation_only","operational_readiness_claimed","operator_review_required","dispatch_allowed","runtime_actions","executes_plan","execute_once_allowed","promotion_allowed","casts","talks","intrusive_actions_performed"],
  "properties":{
    "schema_version":{"const":"ctoa.heal-friend-shadow-trace.v1"},
    "trace_id":{"type":"string","pattern":"^heal-friend-shadow-[0-9a-f]{16}$"},
    "source":{"const":"fixture"},
