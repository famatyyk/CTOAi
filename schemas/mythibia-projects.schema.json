{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "./schemas/mythibia-projects.schema.json",
  "title": "Mythibia Lab Tasks",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "backlog_id", "owner", "scope", "tasks"],
  "properties": {
    "version": { "type": "integer", "minimum": 1 },
    "backlog_id": { "type": "string", "minLength": 1 },
    "owner": { "type": "string", "minLength": 1 },
    "scope": { "type": "string", "minLength": 1 },
    "tasks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "title", "status", "project_folder", "template", "target_url"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "title": { "type": "string", "minLength": 1 },
          "status": { "type": "string", "minLength": 1 },
          "project_folder": { "type": "string", "minLength": 1 },
          "template": { "type": "string", "minLength": 1 },
          "target_url": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
