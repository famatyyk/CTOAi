{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ctoa.local/schemas/conditions-p8-proof.schema.json",
  "title": "CTOAi P8 Operational Proof v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "proof_id",
    "observed_at_unix_ms",
    "status",
    "source",
    "background_status_sha256",
    "live_manifest_sha256",
    "helper_version",
    "conditions_observation_sha256",
    "contract_valid",
    "trusted_live_manifest_pin",
    "live_manifest_parity",
    "live_files_unchanged",
    "exact_active_client_process",
    "fresh_online_heartbeat",
    "helper_version_match",
    "capability_fail_closed",
    "client_process_stable",
    "screenshot_count_stable",
    "no_screen_contract",
    "dispatch_allowed",
    "runtime_actions",
    "executes_plan",
    "execute_once_allowed",
    "promotion_allowed",
    "intrusive_actions_performed"
  ],
  "properties": {
    "schema_version": {"const": "ctoa.p8-operational-proof.v1"},
    "proof_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64,
      "pattern": "^[a-z0-9][a-z0-9._-]*$"
    },
    "observed_at_unix_ms": {"type": "integer", "minimum": 1},
    "status": {"enum": ["ready", "blocked", "unknown"]},
    "source": {"enum": ["background_no_screen", "fixture"]},
    "background_status_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "live_manifest_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "helper_version": {"type": "string", "minLength": 1, "maxLength": 32},
    "conditions_observation_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "contract_valid": {"type": "boolean"},
    "trusted_live_manifest_pin": {"type": "boolean"},
    "live_manifest_parity": {"type": "boolean"},
    "live_files_unchanged": {"type": "boolean"},
    "exact_active_client_process": {"type": "boolean"},
    "fresh_online_heartbeat": {"type": "boolean"},
    "helper_version_match": {"type": "boolean"},
    "capability_fail_closed": {"type": "boolean"},
    "client_process_stable": {"type": "boolean"},
    "screenshot_count_stable": {"type": "boolean"},
    "no_screen_contract": {"type": "boolean"},
    "dispatch_allowed": {"const": false},
    "runtime_actions": {"const": false},
    "executes_plan": {"const": false},
    "execute_once_allowed": {"const": false},
    "promotion_allowed": {"const": false},
    "intrusive_actions_performed": {"type": "array", "maxItems": 0}
  }
}
