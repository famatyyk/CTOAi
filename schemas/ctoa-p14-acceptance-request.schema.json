{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ctoai.local/schemas/ctoa-p14-acceptance-request.schema.json",
  "title": "CTOAi P14 capability-driven acceptance request",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "generated_at",
    "request_id",
    "phase",
    "status",
    "binding",
    "required_capabilities",
    "constraints",
    "evidence_policy",
    "authority",
    "signature"
  ],
  "properties": {
    "schema_version": {"const": "ctoa.p14-acceptance-request.v1"},
    "generated_at": {"type": "string", "format": "date-time"},
    "request_id": {"type": "string", "pattern": "^p14-accept-[a-f0-9]{16}$"},
    "phase": {"const": "P14"},
    "status": {"const": "ready_for_isolated_acceptance"},
    "binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_revision",
        "runner_request_id",
        "runner_result_id",
        "runner_request_sha256",
        "runner_result_sha256",
        "helper_manifest_sha256"
      ],
      "properties": {
        "source_revision": {"type": "string", "pattern": "^[a-f0-9]{40}$"},
        "runner_request_id": {"type": "string", "pattern": "^p14-[a-f0-9]{16}$"},
        "runner_result_id": {"type": "string", "pattern": "^p14-result-[a-f0-9]{16}$"},
        "runner_request_sha256": {"$ref": "#/$defs/sha256"},
        "runner_result_sha256": {"$ref": "#/$defs/sha256"},
        "helper_manifest_sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "required_capabilities": {
      "type": "array",
      "minItems": 1,
      "maxItems": 4,
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/capability"}
    },
    "constraints": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifact_only_handoff",
        "isolated_environment_required",
        "operator_workstation_focus_allowed",
        "operator_workstation_input_allowed",
        "network_dispatch_allowed",
        "live_client_access_allowed",
        "promotion_allowed",
        "sensitive_payload_export_allowed"
      ],
      "properties": {
        "artifact_only_handoff": {"const": true},
        "isolated_environment_required": {"const": true},
        "operator_workstation_focus_allowed": {"const": false},
        "operator_workstation_input_allowed": {"const": false},
        "network_dispatch_allowed": {"const": false},
        "live_client_access_allowed": {"const": false},
        "promotion_allowed": {"const": false},
        "sensitive_payload_export_allowed": {"const": false}
      }
    },
    "evidence_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "digest_algorithm",
        "raw_artifacts_in_control_central",
        "max_artifacts_per_proof",
        "max_bundle_bytes"
      ],
      "properties": {
        "digest_algorithm": {"const": "sha256"},
        "raw_artifacts_in_control_central": {"const": false},
        "max_artifacts_per_proof": {"const": 16},
        "max_bundle_bytes": {"const": 33554432}
      }
    },
    "authority": {"$ref": "#/$defs/authority"},
    "signature": {"$ref": "#/$defs/signature"}
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "capability": {
      "enum": [
        "visual_regression",
        "in_world_regression",
        "canary_rehearsal",
        "rollback_rehearsal"
      ]
    },
    "authority": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "runtime_executor_added",
        "runtime_actions",
        "live_authority",
        "promotion_approved",
        "mcp_write_tool_enabled",
        "p12_reopened"
      ],
      "properties": {
        "runtime_executor_added": {"const": false},
        "runtime_actions": {"const": false},
        "live_authority": {"const": false},
        "promotion_approved": {"const": false},
        "mcp_write_tool_enabled": {"const": false},
        "p12_reopened": {"const": false}
      }
    },
    "signature": {
      "type": "object",
      "additionalProperties": false,
      "required": ["algorithm", "key_id", "value"],
      "properties": {
        "algorithm": {"const": "hmac-sha256"},
        "key_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{2,63}$"},
        "value": {"$ref": "#/$defs/sha256"}
      }
    }
  }
}
