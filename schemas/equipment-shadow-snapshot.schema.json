{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ctoa.local/schemas/equipment-shadow-snapshot.schema.json",
  "title": "CTOAi Equipment Shadow Snapshot v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "observed_at_unix_ms", "observation_id", "online", "alive", "protection_zone", "protection_zone_source", "inventory_revision", "inventory_unambiguous", "slot_name", "rollback_slot_name", "equipped_item_id", "candidate_item_id", "rollback_item_id", "rollback_inventory_revision", "candidate_source_container_id", "rollback_destination_container_id", "cooldown", "cooldown_source", "dispatch_allowed", "runtime_actions", "executes_plan", "execute_once_allowed", "promotion_allowed", "intrusive_actions_performed"],
  "properties": {
    "schema_version": {"const": "ctoa.equipment-shadow-snapshot.v1"},
    "observed_at_unix_ms": {"type": "integer", "minimum": 1},
    "observation_id": {"type": "string", "minLength": 1},
    "online": {"const": true},
    "alive": {"const": true},
    "protection_zone": {"enum": ["outside", "inside", "unknown"]},
    "protection_zone_source": {"type": "string", "minLength": 1},
    "inventory_revision": {"type": "string", "minLength": 1},
    "inventory_unambiguous": {"type": "boolean"},
    "slot_name": {"type": "string", "minLength": 1},
    "rollback_slot_name": {"type": "string", "minLength": 1},
    "equipped_item_id": {"type": "integer", "minimum": 1, "maximum": 65535},
    "candidate_item_id": {"type": "integer", "minimum": 1, "maximum": 65535},
    "rollback_item_id": {"type": "integer", "minimum": 1, "maximum": 65535},
    "rollback_inventory_revision": {"type": "string", "minLength": 1},
    "candidate_source_container_id": {"type": "integer", "minimum": 0},
    "rollback_destination_container_id": {"type": "integer", "minimum": 0},
    "cooldown": {"enum": ["ready", "active", "unknown"]},
    "cooldown_source": {"type": "string", "minLength": 1},
    "dispatch_allowed": {"const": false},
    "runtime_actions": {"const": false},
    "executes_plan": {"const": false},
    "execute_once_allowed": {"const": false},
    "promotion_allowed": {"const": false},
    "intrusive_actions_performed": {"const": []}
  }
}
