{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ctoai.local/schemas/ctoa-p14-runner-request.schema.json",
  "title": "CTOAi P14 independent runner request",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "generated_at",
    "request_id",
    "phase",
    "status",
    "source",
    "runner_contract",
    "replay_checks",
    "artifacts",
    "canary",
    "rollback",
    "authority",
    "signature"
  ],
  "properties": {
    "schema_version": {"const": "ctoa.p14-runner-request.v1"},
    "generated_at": {"type": "string", "format": "date-time"},
    "request_id": {"type": "string", "pattern": "^p14-[a-f0-9]{16}$"},
    "phase": {"const": "P14"},
    "status": {"const": "ready_for_independent_runner"},
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "revision",
        "helper_version",
        "helper_manifest_sha256",
        "roadmap_state_sha256",
        "roadmap_file_sha256",
        "source_file_count"
      ],
      "properties": {
        "revision": {"type": "string", "pattern": "^[a-f0-9]{40}$"},
        "helper_version": {"type": "string", "pattern": "^v[0-9]+\\.[0-9]+\\.[0-9]+$"},
        "helper_manifest_sha256": {"$ref": "#/$defs/sha256"},
        "roadmap_state_sha256": {"$ref": "#/$defs/sha256"},
        "roadmap_file_sha256": {"$ref": "#/$defs/sha256"},
        "source_file_count": {"type": "integer", "minimum": 1, "maximum": 256}
      }
    },
    "runner_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "client_family",
        "required_capabilities",
        "artifact_only_handoff",
        "clean_checkout_required",
        "isolated_display_required",
        "operator_workstation_focus_allowed",
        "operator_workstation_input_allowed",
        "network_dispatch_allowed",
        "live_client_access_allowed"
      ],
      "properties": {
        "client_family": {"const": "mehah-redemption"},
        "required_capabilities": {
          "type": "array",
          "prefixItems": [
            {"const": "module_discovery"},
            {"const": "otmod_metadata"},
            {"const": "g_ui_load_ui"},
            {"const": "g_ui_create_widget"}
          ],
          "items": false,
          "minItems": 4,
          "maxItems": 4
        },
        "artifact_only_handoff": {"const": true},
        "clean_checkout_required": {"const": true},
        "isolated_display_required": {"const": true},
        "operator_workstation_focus_allowed": {"const": false},
        "operator_workstation_input_allowed": {"const": false},
        "network_dispatch_allowed": {"const": false},
        "live_client_access_allowed": {"const": false}
      }
    },
    "replay_checks": {
      "type": "array",
      "prefixItems": [
        {"const": "request_schema"},
        {"const": "bundle_signature"},
        {"const": "roadmap_state_replay"},
        {"const": "helper_manifest_replay"},
        {"const": "rollback_manifest_replay"}
      ],
      "items": false,
      "minItems": 5,
      "maxItems": 5
    },
    "artifacts": {
      "type": "array",
      "prefixItems": [
        {"$ref": "#/$defs/roadmapArtifact"},
        {"$ref": "#/$defs/helperArtifact"},
        {"$ref": "#/$defs/rollbackArtifact"}
      ],
      "items": false,
      "minItems": 3,
      "maxItems": 3
    },
    "canary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "status", "max_changed_files", "promotion_approved", "external_approval_required"],
      "properties": {
        "mode": {"const": "artifact_manifest_only"},
        "status": {"const": "planned_not_executed"},
        "max_changed_files": {"const": 1},
        "promotion_approved": {"const": false},
        "external_approval_required": {"const": true}
      }
    },
    "rollback": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "status", "baseline_manifest_sha256", "live_rollback_allowed"],
      "properties": {
        "mode": {"const": "deterministic_manifest_replay"},
        "status": {"const": "required"},
        "baseline_manifest_sha256": {"$ref": "#/$defs/sha256"},
        "live_rollback_allowed": {"const": false}
      }
    },
    "authority": {"$ref": "#/$defs/authority"},
    "signature": {"$ref": "#/$defs/signature"}
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "safePath": {
      "type": "string",
      "minLength": 1,
      "maxLength": 240,
      "pattern": "^(ctoa_project_loader\\.lua|mods/[A-Za-z0-9._/-]+)$"
    },
    "fileEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "bytes", "sha256"],
      "properties": {
        "path": {"$ref": "#/$defs/safePath"},
        "bytes": {"type": "integer", "minimum": 1, "maximum": 2097152},
        "sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "embeddedArtifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "schema_version", "media_type", "bytes", "sha256", "payload"],
      "properties": {
        "name": {"type": "string"},
        "schema_version": {"type": "string"},
        "media_type": {"type": "string"},
        "bytes": {"type": "integer"},
        "sha256": {"$ref": "#/$defs/sha256"},
        "payload": {}
      }
    },
    "roadmapArtifact": {
      "allOf": [
        {"$ref": "#/$defs/embeddedArtifact"},
        {
          "properties": {
            "name": {"const": "roadmap_state"},
            "schema_version": {"const": "ctoa.roadmap-state.v2"},
            "media_type": {"const": "application/json"},
            "bytes": {"type": "integer", "minimum": 1, "maximum": 262144},
            "sha256": {"$ref": "#/$defs/sha256"},
            "payload": {"type": "object"}
          }
        }
      ]
    },
    "helperArtifact": {
      "allOf": [
        {"$ref": "#/$defs/embeddedArtifact"},
        {
          "properties": {
            "name": {"const": "helper_source_manifest"},
            "schema_version": {"const": "ctoa.p14-helper-source-manifest.v1"},
            "media_type": {"const": "application/json"},
            "bytes": {"type": "integer", "minimum": 1, "maximum": 262144},
            "sha256": {"$ref": "#/$defs/sha256"},
            "payload": {
              "type": "object",
              "additionalProperties": false,
              "required": ["schema_version", "helper_version", "file_count", "files"],
              "properties": {
                "schema_version": {"const": "ctoa.p14-helper-source-manifest.v1"},
                "helper_version": {"type": "string", "pattern": "^v[0-9]+\\.[0-9]+\\.[0-9]+$"},
                "file_count": {"type": "integer", "minimum": 1, "maximum": 256},
                "files": {"type": "array", "minItems": 1, "maxItems": 256, "items": {"$ref": "#/$defs/fileEntry"}}
              }
            }
          }
        }
      ]
    },
    "rollbackArtifact": {
      "allOf": [
        {"$ref": "#/$defs/embeddedArtifact"},
        {
          "properties": {
            "name": {"const": "rollback_baseline"},
            "schema_version": {"const": "ctoa.p14-rollback-baseline.v1"},
            "media_type": {"const": "application/json"},
            "bytes": {"type": "integer", "minimum": 1, "maximum": 262144},
            "sha256": {"$ref": "#/$defs/sha256"},
            "payload": {
              "type": "object",
              "additionalProperties": false,
              "required": ["schema_version", "helper_version", "file_count", "files"],
              "properties": {
                "schema_version": {"const": "ctoa.p14-rollback-baseline.v1"},
                "helper_version": {"type": "string", "pattern": "^v[0-9]+\\.[0-9]+\\.[0-9]+$"},
                "file_count": {"type": "integer", "minimum": 1, "maximum": 256},
                "files": {"type": "array", "minItems": 1, "maxItems": 256, "items": {"$ref": "#/$defs/fileEntry"}}
              }
            }
          }
        }
      ]
    },
    "authority": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "runtime_executor_added",
        "runtime_actions",
        "live_authority",
        "promotion_approved",
        "mcp_write_tool_enabled",
        "p12_reopened"
      ],
      "properties": {
        "runtime_executor_added": {"const": false},
        "runtime_actions": {"const": false},
        "live_authority": {"const": false},
        "promotion_approved": {"const": false},
        "mcp_write_tool_enabled": {"const": false},
        "p12_reopened": {"const": false}
      }
    },
    "signature": {
      "type": "object",
      "additionalProperties": false,
      "required": ["algorithm", "key_id", "value"],
      "properties": {
        "algorithm": {"const": "hmac-sha256"},
        "key_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{2,63}$"},
        "value": {"$ref": "#/$defs/sha256"}
      }
    }
  }
}
