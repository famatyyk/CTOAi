{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ctoa.local/schemas/equipment-shadow-trace.schema.json",
  "title": "CTOAi Equipment Shadow Trace v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "trace_id", "source", "evaluated_at_unix_ms", "input_sha256", "canonical_input_sha256", "status", "decision", "action", "blockers", "plan", "rollback_simulation", "decision_sha256", "operator_review_required", "dispatch_allowed", "runtime_actions", "executes_plan", "execute_once_allowed", "promotion_allowed", "intrusive_actions_performed"],
  "properties": {
    "schema_version": {"const": "ctoa.equipment-shadow-trace.v1"},
    "trace_id": {"type": "string", "minLength": 1},
    "source": {"enum": ["operational", "fixture"]},
    "evaluated_at_unix_ms": {"type": "integer", "minimum": 1},
    "input_sha256": {"type": "object", "additionalProperties": {"type": "string", "pattern": "^[0-9a-f]{64}$"}},
    "canonical_input_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "status": {"enum": ["shadow_plan_ready", "operational_acceptance_blocked"]},
    "decision": {"enum": ["would_plan_ring_swap", "hold"]},
    "action": {"const": "plan_ring_swap"},
    "blockers": {"type": "array", "items": {"type": "string"}},
    "plan": {"type": ["object", "null"]},
    "rollback_simulation": {"enum": ["ready", "blocked"]},
    "decision_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "operator_review_required": {"const": true},
    "dispatch_allowed": {"const": false},
    "runtime_actions": {"const": false},
    "executes_plan": {"const": false},
    "execute_once_allowed": {"const": false},
    "promotion_allowed": {"const": false},
    "intrusive_actions_performed": {"const": []}
  }
}
