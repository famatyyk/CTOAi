{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ctoa.local/schemas/equipment-observation-preview.schema.json",
  "title": "CTOAi Passive Equipment Observation Preview v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "generated_at_unix_ms",
    "status",
    "source",
    "source_sha256",
    "observation_sha256",
    "observation",
    "freshness",
    "provenance",
    "blockers",
    "interaction_contract",
    "dispatch_allowed",
    "runtime_actions",
    "executes_plan",
    "execute_once_allowed",
    "promotion_allowed",
    "intrusive_actions_performed"
  ],
  "properties": {
    "schema_version": {"const": "ctoa.equipment-observation-preview.v1"},
    "generated_at_unix_ms": {"type": "integer", "minimum": 1},
    "status": {"enum": ["preview_ready", "blocked"]},
    "source": {"const": "background_status"},
    "source_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "observation_sha256": {
      "type": ["string", "null"],
      "pattern": "^(?!0{64}$)[0-9a-f]{64}$"
    },
    "observation": {
      "anyOf": [
        {"type": "null"},
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "schema_version",
            "observation_id",
            "observed_at_unix_ms",
            "online",
            "alive",
            "protection_zone",
            "protection_zone_source",
            "inventory_api_available",
            "containers_complete",
            "ring",
            "candidates",
            "cooldown",
            "cooldown_source",
            "producer_source"
          ],
          "properties": {
            "schema_version": {"const": "ctoa.equipment-shadow-observation.v1"},
            "observation_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9_-]{0,63}$"},
            "observed_at_unix_ms": {"type": "integer", "minimum": 1},
            "online": {"enum": ["online", "offline", "unknown"]},
            "alive": {"enum": ["alive", "dead", "unknown"]},
            "protection_zone": {"enum": ["outside", "inside", "unknown"]},
            "protection_zone_source": {"enum": ["player_method", "player_states", "unavailable"]},
            "inventory_api_available": {"type": "boolean"},
            "containers_complete": {"type": "boolean"},
            "ring": {
              "type": "object",
              "additionalProperties": false,
              "required": ["present", "item_id", "count"],
              "properties": {
                "present": {"type": "boolean"},
                "item_id": {"type": "integer", "minimum": 0, "maximum": 65535},
                "count": {"type": "integer", "minimum": 0, "maximum": 65535}
              }
            },
            "candidates": {
              "type": "array",
              "maxItems": 256,
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["container_id", "slot_index", "item_id", "count"],
                "properties": {
                  "container_id": {"type": "integer", "minimum": 0, "maximum": 65535},
                  "slot_index": {"type": "integer", "minimum": 1, "maximum": 65535},
                  "item_id": {"type": "integer", "minimum": 1, "maximum": 65535},
                  "count": {"type": "integer", "minimum": 1, "maximum": 65535}
                }
              }
            },
            "cooldown": {"enum": ["ready", "active", "unknown"]},
            "cooldown_source": {"enum": ["game_cooldown_group", "unavailable"]},
            "producer_source": {"enum": ["otclient_guarded_adapter", "fixture"]}
          }
        }
      ]
    },
    "freshness": {
      "type": "object",
      "additionalProperties": false,
      "required": ["observed_at_unix_ms", "age_ms", "max_age_ms", "fresh"],
      "properties": {
        "observed_at_unix_ms": {"type": ["integer", "null"], "minimum": 1},
        "age_ms": {"type": ["integer", "null"]},
        "max_age_ms": {"const": 10000},
        "fresh": {"type": "boolean"}
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "producer_source",
        "background_status_sha256",
        "background_schema_version",
        "background_capability_fresh",
        "background_contract_valid",
        "version_match"
      ],
      "properties": {
        "producer_source": {"type": ["string", "null"]},
        "background_status_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "background_schema_version": {"type": ["string", "null"]},
        "background_capability_fresh": {"type": "boolean"},
        "background_contract_valid": {"type": "boolean"},
        "version_match": {"type": "boolean"}
      }
    },
    "blockers": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "enum": [
          "background_missing",
          "background_invalid",
          "background_not_ready",
          "background_contract_invalid",
          "equipment_observation_missing",
          "equipment_observation_invalid",
          "equipment_observation_future",
          "equipment_observation_stale",
          "equipment_observation_provenance_untrusted",
          "player_offline",
          "player_dead",
          "protection_zone_inside",
          "protection_zone_unknown",
          "protection_zone_source_untrusted",
          "inventory_api_unavailable",
          "containers_incomplete",
          "ring_missing",
          "cooldown_active",
          "cooldown_unknown",
          "cooldown_source_untrusted",
          "unsafe_contract"
        ]
      }
    },
    "interaction_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "gui_automation",
        "mouse_keyboard_input",
        "window_focus",
        "screenshot_capture",
        "client_launch",
        "client_stop",
        "live_file_writes",
        "passive_reads_only",
        "evidence_write_scope"
      ],
      "properties": {
        "gui_automation": {"const": false},
        "mouse_keyboard_input": {"const": false},
        "window_focus": {"const": false},
        "screenshot_capture": {"const": false},
        "client_launch": {"const": false},
        "client_stop": {"const": false},
        "live_file_writes": {"const": false},
        "passive_reads_only": {"const": true},
        "evidence_write_scope": {"const": "runtime/solteria_helper_dev"}
      }
    },
    "dispatch_allowed": {"const": false},
    "runtime_actions": {"const": false},
    "executes_plan": {"const": false},
    "execute_once_allowed": {"const": false},
    "promotion_allowed": {"const": false},
    "intrusive_actions_performed": {"const": []}
  },
  "allOf": [
    {
      "if": {"properties": {"status": {"const": "preview_ready"}}},
      "then": {"properties": {"blockers": {"maxItems": 0}, "observation": {"type": "object"}}}
    },
    {
      "if": {"properties": {"status": {"const": "blocked"}}},
      "then": {"properties": {"blockers": {"minItems": 1}}}
    }
  ]
}
