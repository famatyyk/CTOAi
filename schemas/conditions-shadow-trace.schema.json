{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ctoa.local/schemas/conditions-shadow-trace.schema.json",
  "title": "CTOAi Conditions Shadow Trace v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "trace_id",
    "source",
    "evaluated_at_unix_ms",
    "mode",
    "action",
    "condition",
    "spell",
    "input_sha256",
    "canonical_input_sha256",
    "observation_age_ms",
    "p8_age_ms",
    "recovery_trace_age_ms",
    "recovery_age_ms",
    "status",
    "decision",
    "blockers",
    "decision_sha256",
    "operator_review_required",
    "dispatch_allowed",
    "runtime_actions",
    "executes_plan",
    "execute_once_allowed",
    "promotion_allowed",
    "intrusive_actions_performed"
  ],
  "properties": {
    "schema_version": {"const": "ctoa.conditions-shadow-trace.v1"},
    "trace_id": {"type": "string", "pattern": "^conditions-shadow-[0-9a-f]{16}$"},
    "source": {"enum": ["operational", "fixture"]},
    "evaluated_at_unix_ms": {"type": "integer", "minimum": 1},
    "mode": {"const": "shadow_only"},
    "action": {"const": "plan_paralyze_recovery"},
    "condition": {"const": "paralyze"},
    "spell": {"const": "exura"},
    "input_sha256": {
      "type": "object",
      "additionalProperties": false,
      "required": ["profile", "observation", "p8_proof", "recovery_trace", "recovery_proof"],
      "properties": {
        "profile": {"type": "string", "pattern": "^(?!0{64}$)[0-9a-f]{64}$"},
        "observation": {"type": "string", "pattern": "^(?!0{64}$)[0-9a-f]{64}$"},
        "p8_proof": {"type": "string", "pattern": "^(?!0{64}$)[0-9a-f]{64}$"},
        "recovery_trace": {"type": "string", "pattern": "^(?!0{64}$)[0-9a-f]{64}$"},
        "recovery_proof": {"type": "string", "pattern": "^(?!0{64}$)[0-9a-f]{64}$"}
      }
    },
    "canonical_input_sha256": {"type": "string", "pattern": "^(?!0{64}$)[0-9a-f]{64}$"},
    "observation_age_ms": {"type": ["integer", "null"]},
    "p8_age_ms": {"type": ["integer", "null"]},
    "recovery_trace_age_ms": {"type": ["integer", "null"]},
    "recovery_age_ms": {"type": ["integer", "null"]},
    "status": {"enum": ["shadow_plan_ready", "operational_acceptance_blocked"]},
    "decision": {"enum": ["would_plan_paralyze_recovery", "hold"]},
    "blockers": {
      "type": "array",
      "maxItems": 96,
      "items": {"type": "string", "minLength": 1, "maxLength": 64}
    },
    "decision_sha256": {"type": "string", "pattern": "^(?!0{64}$)[0-9a-f]{64}$"},
    "operator_review_required": {"const": true},
    "dispatch_allowed": {"const": false},
    "runtime_actions": {"const": false},
    "executes_plan": {"const": false},
    "execute_once_allowed": {"const": false},
    "promotion_allowed": {"const": false},
    "intrusive_actions_performed": {"type": "array", "maxItems": 0}
  }
}
