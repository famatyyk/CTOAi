{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ctoa.local/schemas/equipment-operator-refresh-run.schema.json",
  "title": "CTOAi P10 Equipment Operator Refresh Run v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "status",
    "run_id",
    "started_at_unix_ms",
    "completed_at_unix_ms",
    "duration_ms",
    "stage_count",
    "stage_order",
    "stage_receipts",
    "artifact_hashes",
    "source_statuses",
    "source_blockers",
    "canonical_aggregate_sha256",
    "artifact_skew_ms",
    "max_artifact_skew_ms",
    "oldest_artifact_age_ms",
    "freshness_max_age_ms",
    "hashes_verified",
    "schemas_verified",
    "no_action_verified",
    "eligibility_verified",
    "mixed_run_detected",
    "stale_artifact_detected",
    "hash_mismatch_detected",
    "all_source_stages_ready",
    "operator_inputs_ready_observed",
    "eligibility_changed",
    "eligibility_state",
    "acceptance_granted",
    "operational_readiness_claimed",
    "runtime_actions",
    "dispatch_allowed",
    "executes_plan",
    "execute_once_allowed",
    "promotion_allowed",
    "live_file_writes",
    "intrusive_actions_performed",
    "live_safety"
  ],
  "properties": {
    "schema_version": {"const": "ctoa.equipment-operator-refresh-run.v1"},
    "status": {"const": "completed"},
    "run_id": {"type": "string", "format": "uuid", "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-4[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"},
    "started_at_unix_ms": {"type": "integer", "minimum": 1},
    "completed_at_unix_ms": {"type": "integer", "minimum": 1},
    "duration_ms": {"type": "integer", "minimum": 0, "maximum": 30000},
    "stage_count": {"const": 7},
    "stage_order": {"$ref": "#/$defs/stageOrder"},
    "stage_receipts": {
      "type": "array",
      "minItems": 7,
      "maxItems": 7,
      "prefixItems": [
        {"$ref": "#/$defs/receipt1"},
        {"$ref": "#/$defs/receipt2"},
        {"$ref": "#/$defs/receipt3"},
        {"$ref": "#/$defs/receipt4"},
        {"$ref": "#/$defs/receipt5"},
        {"$ref": "#/$defs/receipt6"},
        {"$ref": "#/$defs/receipt7"}
      ],
      "items": false
    },
    "artifact_hashes": {"$ref": "#/$defs/hashMap"},
    "source_statuses": {"$ref": "#/$defs/statusMap"},
    "source_blockers": {"$ref": "#/$defs/blockerMap"},
    "canonical_aggregate_sha256": {"$ref": "#/$defs/sha256"},
    "artifact_skew_ms": {"type": "integer", "minimum": 0, "maximum": 30000},
    "max_artifact_skew_ms": {"const": 30000},
    "oldest_artifact_age_ms": {"type": "integer", "minimum": 0, "maximum": 30000},
    "freshness_max_age_ms": {"const": 30000},
    "hashes_verified": {"const": true},
    "schemas_verified": {"const": true},
    "no_action_verified": {"const": true},
    "eligibility_verified": {"const": true},
    "mixed_run_detected": {"const": false},
    "stale_artifact_detected": {"const": false},
    "hash_mismatch_detected": {"const": false},
    "all_source_stages_ready": {"type": "boolean"},
    "operator_inputs_ready_observed": {"type": "boolean"},
    "eligibility_changed": {"const": false},
    "eligibility_state": {"const": "unchanged"},
    "acceptance_granted": {"const": false},
    "operational_readiness_claimed": {"const": false},
    "runtime_actions": {"const": false},
    "dispatch_allowed": {"const": false},
    "executes_plan": {"const": false},
    "execute_once_allowed": {"const": false},
    "promotion_allowed": {"const": false},
    "live_file_writes": {"const": false},
    "intrusive_actions_performed": {"const": []},
    "live_safety": {"type": "string", "minLength": 64}
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "stringList": {"type": "array", "uniqueItems": true, "items": {"type": "string"}},
    "stageOrder": {
      "const": [
        "capture_profile_doctor",
        "observation_preview",
        "dependency_preflight",
        "candidate_catalog",
        "capture_profile_change_plan",
        "operator_readiness",
        "consumer_parity"
      ]
    },
    "stageIds": {
      "enum": [
        "capture_profile_doctor",
        "observation_preview",
        "dependency_preflight",
        "candidate_catalog",
        "capture_profile_change_plan",
        "operator_readiness",
        "consumer_parity"
      ]
    },
    "receipt": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "stage_index",
        "stage_id",
        "artifact_filename",
        "schema_version",
        "reported_status",
        "blockers",
        "artifact_sha256",
        "artifact_modified_at_unix_ms",
        "source_timestamp_unix_ms",
        "recorded_at_unix_ms",
        "no_action_valid",
        "eligibility_valid"
      ],
      "properties": {
        "stage_index": {"type": "integer", "minimum": 1, "maximum": 7},
        "stage_id": {"$ref": "#/$defs/stageIds"},
        "artifact_filename": {"type": "string", "pattern": "^equipment_.+\\.json$"},
        "schema_version": {"type": "string", "pattern": "^ctoa\\.equipment-.+\\.v1$"},
        "reported_status": {"type": "string", "minLength": 1},
        "blockers": {"$ref": "#/$defs/stringList"},
        "artifact_sha256": {"$ref": "#/$defs/sha256"},
        "artifact_modified_at_unix_ms": {"type": "integer", "minimum": 1},
        "source_timestamp_unix_ms": {"type": ["integer", "null"], "minimum": 1},
        "recorded_at_unix_ms": {"type": "integer", "minimum": 1},
        "no_action_valid": {"const": true},
        "eligibility_valid": {"const": true}
      }
    },
    "receipt1": {"allOf": [{"$ref": "#/$defs/receipt"}, {"properties": {"stage_index": {"const": 1}, "stage_id": {"const": "capture_profile_doctor"}, "artifact_filename": {"const": "equipment_capture_profile_doctor.json"}}}]},
    "receipt2": {"allOf": [{"$ref": "#/$defs/receipt"}, {"properties": {"stage_index": {"const": 2}, "stage_id": {"const": "observation_preview"}, "artifact_filename": {"const": "equipment_observation_preview.json"}}}]},
    "receipt3": {"allOf": [{"$ref": "#/$defs/receipt"}, {"properties": {"stage_index": {"const": 3}, "stage_id": {"const": "dependency_preflight"}, "artifact_filename": {"const": "equipment_dependency_preflight.json"}}}]},
    "receipt4": {"allOf": [{"$ref": "#/$defs/receipt"}, {"properties": {"stage_index": {"const": 4}, "stage_id": {"const": "candidate_catalog"}, "artifact_filename": {"const": "equipment_candidate_catalog.json"}}}]},
    "receipt5": {"allOf": [{"$ref": "#/$defs/receipt"}, {"properties": {"stage_index": {"const": 5}, "stage_id": {"const": "capture_profile_change_plan"}, "artifact_filename": {"const": "equipment_capture_profile_change_plan.json"}}}]},
    "receipt6": {"allOf": [{"$ref": "#/$defs/receipt"}, {"properties": {"stage_index": {"const": 6}, "stage_id": {"const": "operator_readiness"}, "artifact_filename": {"const": "equipment_operator_readiness.json"}}}]},
    "receipt7": {"allOf": [{"$ref": "#/$defs/receipt"}, {"properties": {"stage_index": {"const": 7}, "stage_id": {"const": "consumer_parity"}, "artifact_filename": {"const": "equipment_consumer_parity.json"}}}]},
    "hashMap": {
      "type": "object",
      "additionalProperties": false,
      "required": ["capture_profile_doctor", "observation_preview", "dependency_preflight", "candidate_catalog", "capture_profile_change_plan", "operator_readiness", "consumer_parity"],
      "properties": {
        "capture_profile_doctor": {"$ref": "#/$defs/sha256"},
        "observation_preview": {"$ref": "#/$defs/sha256"},
        "dependency_preflight": {"$ref": "#/$defs/sha256"},
        "candidate_catalog": {"$ref": "#/$defs/sha256"},
        "capture_profile_change_plan": {"$ref": "#/$defs/sha256"},
        "operator_readiness": {"$ref": "#/$defs/sha256"},
        "consumer_parity": {"$ref": "#/$defs/sha256"}
      }
    },
    "statusMap": {
      "type": "object",
      "additionalProperties": false,
      "required": ["capture_profile_doctor", "observation_preview", "dependency_preflight", "candidate_catalog", "capture_profile_change_plan", "operator_readiness", "consumer_parity"],
      "properties": {
        "capture_profile_doctor": {"type": "string"},
        "observation_preview": {"type": "string"},
        "dependency_preflight": {"type": "string"},
        "candidate_catalog": {"type": "string"},
        "capture_profile_change_plan": {"type": "string"},
        "operator_readiness": {"type": "string"},
        "consumer_parity": {"type": "string"}
      }
    },
    "blockerMap": {
      "type": "object",
      "additionalProperties": false,
      "required": ["capture_profile_doctor", "observation_preview", "dependency_preflight", "candidate_catalog", "capture_profile_change_plan", "operator_readiness", "consumer_parity"],
      "properties": {
        "capture_profile_doctor": {"$ref": "#/$defs/stringList"},
        "observation_preview": {"$ref": "#/$defs/stringList"},
        "dependency_preflight": {"$ref": "#/$defs/stringList"},
        "candidate_catalog": {"$ref": "#/$defs/stringList"},
        "capture_profile_change_plan": {"$ref": "#/$defs/stringList"},
        "operator_readiness": {"$ref": "#/$defs/stringList"},
        "consumer_parity": {"$ref": "#/$defs/stringList"}
      }
    }
  }
}
