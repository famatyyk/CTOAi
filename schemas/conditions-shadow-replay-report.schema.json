{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ctoa.local/schemas/conditions-shadow-replay-report.schema.json",
  "title": "CTOAi Conditions Shadow Replay Report v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "generated_at_unix_ms",
    "mode",
    "operational_acceptance_status",
    "scenario_pack_status",
    "fixture_only_validation_passed",
    "runtime_readiness_claimed",
    "operational_trace",
    "scenario_pack",
    "dispatch_allowed",
    "runtime_actions",
    "executes_plan",
    "execute_once_allowed",
    "promotion_allowed",
    "intrusive_actions_performed"
  ],
  "properties": {
    "schema_version": {"const": "ctoa.conditions-shadow-replay-report.v1"},
    "generated_at_unix_ms": {"type": "integer", "minimum": 1},
    "mode": {"const": "offline_shadow_replay"},
    "operational_acceptance_status": {"enum": ["shadow_plan_ready_for_operator_review", "operational_acceptance_blocked"]},
    "scenario_pack_status": {"enum": ["passed", "failed"]},
    "fixture_only_validation_passed": {"type": "boolean"},
    "runtime_readiness_claimed": {"const": false},
    "operational_trace": {"$ref": "conditions-shadow-trace.schema.json"},
    "scenario_pack": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "fixture_only",
        "operational_readiness_claimed",
        "scenario_pack_sha256",
        "total_count",
        "passed_count",
        "failed_count",
        "cases",
        "dispatch_allowed",
        "runtime_actions",
        "executes_plan",
        "execute_once_allowed",
        "promotion_allowed",
        "intrusive_actions_performed"
      ],
      "properties": {
        "status": {"enum": ["passed", "failed"]},
        "fixture_only": {"const": true},
        "operational_readiness_claimed": {"const": false},
        "scenario_pack_sha256": {"type": "string", "pattern": "^(?!0{64}$)[0-9a-f]{64}$"},
        "total_count": {"type": "integer", "minimum": 0},
        "passed_count": {"type": "integer", "minimum": 0},
        "failed_count": {"type": "integer", "minimum": 0},
        "cases": {
          "type": "array",
          "maxItems": 128,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "name",
              "mutation",
              "expected_status",
              "actual_status",
              "expected_blockers",
              "blockers",
              "canonical_input_sha256",
              "decision_sha256",
              "deterministic",
              "passed",
              "dispatch_allowed",
              "runtime_actions",
              "executes_plan",
              "execute_once_allowed",
              "promotion_allowed",
              "intrusive_actions_performed"
            ],
            "properties": {
              "name": {"type": "string", "minLength": 1, "maxLength": 64},
              "mutation": {"type": "string", "minLength": 1, "maxLength": 64},
              "expected_status": {"enum": ["shadow_plan_ready", "operational_acceptance_blocked"]},
              "actual_status": {"enum": ["shadow_plan_ready", "operational_acceptance_blocked"]},
              "expected_blockers": {"type": "array", "maxItems": 96, "items": {"type": "string", "maxLength": 64}},
              "blockers": {"type": "array", "maxItems": 96, "items": {"type": "string", "maxLength": 64}},
              "canonical_input_sha256": {"type": "string", "pattern": "^(?!0{64}$)[0-9a-f]{64}$"},
              "decision_sha256": {"type": "string", "pattern": "^(?!0{64}$)[0-9a-f]{64}$"},
              "deterministic": {"type": "boolean"},
              "passed": {"type": "boolean"},
              "dispatch_allowed": {"const": false},
              "runtime_actions": {"const": false},
              "executes_plan": {"const": false},
              "execute_once_allowed": {"const": false},
              "promotion_allowed": {"const": false},
              "intrusive_actions_performed": {"type": "array", "maxItems": 0}
            }
          }
        },
        "dispatch_allowed": {"const": false},
        "runtime_actions": {"const": false},
        "executes_plan": {"const": false},
        "execute_once_allowed": {"const": false},
        "promotion_allowed": {"const": false},
        "intrusive_actions_performed": {"type": "array", "maxItems": 0}
      }
    },
    "dispatch_allowed": {"const": false},
    "runtime_actions": {"const": false},
    "executes_plan": {"const": false},
    "execute_once_allowed": {"const": false},
    "promotion_allowed": {"const": false},
    "intrusive_actions_performed": {"type": "array", "maxItems": 0}
  }
}
