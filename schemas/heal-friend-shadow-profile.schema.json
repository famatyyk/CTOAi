{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ctoa.local/schemas/heal-friend-shadow-profile.schema.json",
  "title": "CTOAi Heal Friend fixture-only profile v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version","mode","action","spell","selection_policy","whitelist","whitelist_revision","hp_threshold","max_range","max_observation_age_ms","max_party_age_ms","cooldown_required","retry_budget","requires_p9_acceptance","requires_p10_acceptance","require_party_membership","prohibit_self","require_visible","require_same_floor","dispatch_allowed","runtime_actions","executes_plan","execute_once_allowed","promotion_allowed","casts","talks"],
  "properties": {
    "schema_version": {"const": "ctoa.heal-friend-shadow-profile.v1"},
    "mode": {"const": "shadow_only"},
    "action": {"const": "plan_sio"},
    "spell": {"const": "exura sio"},
    "selection_policy": {"const": "single_exact_target"},
    "whitelist": {"type":"array","minItems":1,"maxItems":1,"items":{"type":"object","additionalProperties":false,"required":["target_id","target_name"],"properties":{"target_id":{"type":"integer","minimum":1},"target_name":{"type":"string","pattern":"^[a-z][a-z0-9 ]{0,63}$"}}}},
    "whitelist_revision": {"type":"string","pattern":"^[0-9a-f]{64}$"},
    "hp_threshold": {"type":"integer","minimum":1,"maximum":100},
    "max_range": {"const": 7},
    "max_observation_age_ms": {"const": 6000},
    "max_party_age_ms": {"const": 6000},
    "cooldown_required": {"const": "ready"},
    "retry_budget": {"const": 0},
    "requires_p9_acceptance": {"const": true},
    "requires_p10_acceptance": {"const": true},
    "require_party_membership": {"const": true},
    "prohibit_self": {"const": true},
    "require_visible": {"const": true},
    "require_same_floor": {"const": true},
    "dispatch_allowed": {"const": false},
    "runtime_actions": {"const": false},
    "executes_plan": {"const": false},
    "execute_once_allowed": {"const": false},
    "promotion_allowed": {"const": false},
    "casts": {"const": false},
    "talks": {"const": false}
  }
}
