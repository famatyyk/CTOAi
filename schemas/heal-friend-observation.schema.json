{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ctoa.local/schemas/heal-friend-observation.schema.json",
  "title": "CTOAi Heal Friend fixture observation v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version","observation_id","observed_at_unix_ms","party_observed_at_unix_ms","producer_source","online","alive","protection_zone","protection_zone_source","self_id","target_id","observed_target_id","current_target_id","target_name","observed_target_name","current_target_name","whitelist_revision","party_member_ids","target_is_player","target_is_self","target_visible","target_same_floor","distance","observed_target_hp_percent","current_target_hp_percent","cooldown","cooldown_source","dispatch_allowed","runtime_actions","executes_plan","execute_once_allowed","promotion_allowed","casts","talks","intrusive_actions_performed"],
  "properties": {
    "schema_version": {"const":"ctoa.heal-friend-observation.v1"},
    "observation_id": {"type":"string","pattern":"^[a-z0-9][a-z0-9_-]{0,63}$"},
    "observed_at_unix_ms": {"type":"integer","minimum":1},
    "party_observed_at_unix_ms": {"type":"integer","minimum":1},
    "producer_source": {"enum":["fixture","otclient_guarded_adapter"]},
    "online": {"enum":["online","offline","unknown"]},
    "alive": {"enum":["alive","dead","unknown"]},
    "protection_zone": {"enum":["outside","inside","unknown"]},
    "protection_zone_source": {"enum":["player_method","unavailable"]},
    "self_id": {"type":"integer","minimum":1},
    "target_id": {"type":"integer","minimum":1},
    "observed_target_id": {"type":"integer","minimum":1},
    "current_target_id": {"type":"integer","minimum":1},
    "target_name": {"type":"string","pattern":"^[a-z][a-z0-9 ]{0,63}$"},
    "observed_target_name": {"type":"string","pattern":"^[a-z][a-z0-9 ]{0,63}$"},
    "current_target_name": {"type":"string","pattern":"^[a-z][a-z0-9 ]{0,63}$"},
    "whitelist_revision": {"type":"string","pattern":"^[0-9a-f]{64}$"},
    "party_member_ids": {"type":"array","maxItems":64,"uniqueItems":true,"items":{"type":"integer","minimum":1}},
    "target_is_player": {"type":"boolean"},
    "target_is_self": {"type":"boolean"},
    "target_visible": {"type":"boolean"},
    "target_same_floor": {"type":"boolean"},
    "distance": {"type":"integer","minimum":0,"maximum":255},
    "observed_target_hp_percent": {"type":"integer","minimum":1,"maximum":100},
    "current_target_hp_percent": {"type":"integer","minimum":1,"maximum":100},
    "cooldown": {"enum":["ready","active","unknown"]},
    "cooldown_source": {"enum":["game_cooldown_group","unavailable"]},
    "dispatch_allowed": {"const":false},
    "runtime_actions": {"const":false},
    "executes_plan": {"const":false},
    "execute_once_allowed": {"const":false},
    "promotion_allowed": {"const":false},
    "casts": {"const":false},
    "talks": {"const":false},
    "intrusive_actions_performed": {"const":[]}
  }
}
