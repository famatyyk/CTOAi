{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ctoai.local/schemas/ctoa-p14-acceptance-result.schema.json",
  "title": "CTOAi P14 signed isolated acceptance result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "generated_at",
    "result_id",
    "request_id",
    "request_sha256",
    "status",
    "source_revision",
    "isolation",
    "capabilities",
    "blockers",
    "authority",
    "signature"
  ],
  "properties": {
    "schema_version": {"const": "ctoa.p14-acceptance-result.v1"},
    "generated_at": {"type": "string", "format": "date-time"},
    "result_id": {"type": "string", "pattern": "^p14-accept-result-[a-f0-9]{16}$"},
    "request_id": {"type": "string", "pattern": "^p14-accept-[a-f0-9]{16}$"},
    "request_sha256": {"$ref": "#/$defs/sha256"},
    "status": {"enum": ["passed", "partial", "blocked"]},
    "source_revision": {"type": "string", "pattern": "^[a-f0-9]{40}$"},
    "isolation": {"$ref": "ctoa-p14-acceptance-report.schema.json#/$defs/isolation"},
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "maxItems": 4,
      "items": {"$ref": "ctoa-p14-acceptance-report.schema.json#/$defs/capabilityResult"}
    },
    "blockers": {
      "type": "array",
      "maxItems": 4,
      "uniqueItems": true,
      "items": {
        "enum": [
          "p14_visual_regression_not_proven",
          "p14_in_world_regression_not_proven",
          "p14_canary_rehearsal_not_proven",
          "p14_rollback_rehearsal_not_proven"
        ]
      }
    },
    "authority": {"$ref": "ctoa-p14-acceptance-request.schema.json#/$defs/authority"},
    "signature": {"$ref": "ctoa-p14-acceptance-request.schema.json#/$defs/signature"}
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
  }
}
